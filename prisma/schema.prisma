generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  logoUrl        String?
  timezone       String          @default("UTC")
  subscriptionPlan     String   @default("STARTER")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt      DateTime        @default(now())
  pricingProfile PricingProfile?
  quoteRequests  QuoteRequest[]
  widgetSettings WidgetSettings?
}

model PricingProfile {
  id                String  @id @default(cuid())
  companyId         String  @unique
  baseRatePerMile   Float   @default(2.50)
  minimumCharge     Float   @default(35.00)
  useMinimumCharge  Boolean @default(true)
  minMilesThreshold Float   @default(0)
  weightFee         Float   @default(0)
  itemCountFee      Float   @default(0)
  stairsFee         Float   @default(0)
  insideDeliveryFee Float   @default(0)
  afterHoursFee       Float   @default(0)
  businessHoursStart  String  @default("08:00")
  businessHoursEnd    String  @default("18:00")
  businessDays        String  @default("1,2,3,4,5")
  largeItemFee        Float   @default(0)
  largeItemsEnabled   Boolean @default(false)
  largeItemCategories Json    @default("[]")
  company             Company @relation(fields: [companyId], references: [id])
}

model WidgetSettings {
  id                 String  @id @default(cuid())
  companyId          String  @unique
  showWeight         Boolean @default(false)
  showItemCount      Boolean @default(true)
  showExtras         Boolean @default(true)
  primaryColor       String  @default("#1E40AF")
  buttonText         String  @default("Get Instant Quote")
  headerText         String  @default("Delivery Quote Calculator")
  disclaimerText     String  @default("Estimate only. Final price confirmed after booking.")
  companyNameText      String?
  companyNameFont      String  @default("Inter")
  backgroundImageUrl   String?
  company            Company @relation(fields: [companyId], references: [id])
}

model QuoteRequest {
  id             String   @id @default(cuid())
  companyId      String
  customerName   String
  customerEmail  String
  customerPhone  String?
  pickupZip      String
  dropoffZip     String
  distanceMiles  Float
  serviceType    String
  packageSize    String?
  packageWeight  String?
  selectedExtras String?
  status         String   @default("PENDING")
  estimatedPrice Float
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id])
}
